---
import SocialLinks from "./SocialLinks.astro";

const today = new Date();
---

<footer aria-label="Site Info">
  <div class="footer-content">
    <SocialLinks showRss={true} />

    <div class="divider"></div>

    <div class="copyright">
      <p>
        © <time>{today.getFullYear()}</time>
        <a href="https://github.com/tylercrosse">Tyler Crosse</a>.
        <span>Some rights reserved.</span>
      </p>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 1rem;
    color: var(--sol-1);
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
    flex-wrap: wrap;
    padding-top: 1rem;
    border-top: 1px solid var(--base4);
  }

  :global([data-effective-theme="dark"]) .footer-content {
    border-top: 1px solid var(--base01);
  }

  .divider {
    width: 1px;
    height: 2rem;
    background-color: var(--base4);
  }

  :global([data-effective-theme="dark"]) .divider {
    background-color: var(--base01);
  }

  .copyright {
    color: var(--base01);
    font-size: 0.9rem;
  }

  .copyright p {
    margin: 0;
    line-height: 1.5;
  }

  .copyright a {
    color: var(--sol-1);
    text-decoration: none;
  }

  .copyright a:hover {
    color: var(--sol-9);
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .footer-content {
      flex-direction: column;
      gap: 1rem;
    }

    .divider {
      width: 2rem;
      height: 1px;
    }
  }
</style>

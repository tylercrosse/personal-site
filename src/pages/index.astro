---
import { getCollection } from "astro:content";
import readingTime from "reading-time";

import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import SocialLinks from "../components/SocialLinks.astro";
import CurrentlyList from "../components/CurrentlyList.astro";

const posts = (await getCollection("ideas"))
  .filter((post) => import.meta.env.DEV || !post.data.draft)
  .sort((a, b) => {
    const aDate = a.data.pubDate || a.data.date;
    const bDate = b.data.pubDate || b.data.date;
    return new Date(bDate || 0).valueOf() - new Date(aDate || 0).valueOf();
  });

const allPostsData = posts.map((post) => {
  const slug = post.id.replace(/(\/index)?\.(md|mdx)$/, "");
  const stats = readingTime(post.body || "");
  return {
    id: post.id,
    slug,
    title: post.data.title,
    description: post.data.description,
    date: post.data.pubDate || post.data.date,
    type: post.data.type,
    status: post.data.status,
    tags: post.data.tags || [],
    image: post.data.image,
    draft: post.data.draft,
    featured: post.data.featured,
    readingTimeText: stats.text,
  };
});

const featured = allPostsData.filter((p) => p.featured).slice(0, 3);
const featuredIds = new Set(featured.map((p) => p.id));
const notebook = allPostsData
  .filter((p) => !featuredIds.has(p.id))
  .slice(0, 4);

const currentlyItems = [
  { label: "Open to full-time roles", tone: "active" as const },
  { label: "Applying — MATS '26", tone: "pending" as const },
  { label: "Considering PhD programs", tone: "pending" as const },
  { label: "SPAR & MARS fellow", tone: "muted" as const },
  { label: "Wrapping MSCS @ Georgia Tech", tone: "muted" as const },
];
---

<BaseLayout title="Home">
  <section class="profile slide-in-block">
    <div class="profile-main">
      <h1 class="profile-name">Tyler Crosse</h1>
      <p class="profile-bio">
        Research engineer working on AI safety — interpretability & ML infra.
        MSCS Georgia Tech. 7+ years as a senior SWE & team lead.
      </p>
      <SocialLinks showRss={false} />
    </div>
    <CurrentlyList items={currentlyItems} />
  </section>

  <hr class="divider slide-in-block" />

  {featured.length > 0 && (
    <section class="showcase slide-in-block" aria-label="Featured posts">
      <div class="showcase-hero">
        <PostCard post={featured[0]} variant="showcase" />
      </div>
      <div class="showcase-rail">
        {featured.slice(1, 3).map((post) => (
          <PostCard post={post} variant="compact" />
        ))}
      </div>
    </section>
  )}

  <section class="notebook slide-in-block" aria-label="From the notebook">
    <header class="notebook-header">
      <h2>From the notebook</h2>
      <a href="/ideas" class="notebook-all">all ideas →</a>
    </header>
    <div class="notebook-grid">
      {notebook.map((post) => (
        <PostCard post={post} variant="mini" />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  :global(main) {
    padding: 2rem 1.5rem 4rem;
  }

  @media (min-width: 768px) {
    :global(main) {
      padding: 3rem 2rem 5rem;
    }
  }

  /* Profile header */
  .profile {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto 2rem;
  }

  @media (min-width: 768px) {
    .profile {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
      gap: 3rem;
    }
  }

  .profile-main {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 36rem;
  }

  .profile-name {
    font-family: var(--font-heading);
    font-size: clamp(2.75rem, 6vw, 4.25rem);
    line-height: 1;
    margin: 0;
    font-weight: 700;
  }

  .profile-bio {
    margin: 0;
    color: var(--sol-8);
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    line-height: 1.55;
    max-width: 32rem;
  }

  .profile :global(.social-links) {
    margin-left: -0.5rem;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--main-border-color);
    max-width: 1200px;
    margin: 0 auto 2rem;
  }

  :global([data-effective-theme="dark"]) .divider {
    border-top-color: var(--base03);
  }

  /* Showcase */
  .showcase {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto 3rem;
  }

  @media (min-width: 900px) {
    .showcase {
      grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
      gap: 1.75rem;
    }
  }

  .showcase-rail {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 600px) and (max-width: 899px) {
    .showcase-rail {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Notebook */
  .notebook {
    max-width: 1200px;
    margin: 0 auto;
  }

  .notebook-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    gap: 1rem;
  }

  .notebook-header h2 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0;
  }

  .notebook-all {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--sol-8);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .notebook-all:hover {
    color: var(--sol-9);
  }

  .notebook-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 600px) {
    .notebook-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .notebook-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Entrance animations */
  .slide-in-block {
    opacity: 0;
    filter: blur(8px);
    transform: scale(0.98);
    will-change: transform, opacity, filter;
    animation: slideInBlock 0.45s cubic-bezier(0.43, 0.195, 0.02, 1) forwards;
  }

  .profile.slide-in-block {
    animation-delay: 0.05s;
  }
  .divider.slide-in-block {
    animation-delay: 0.15s;
  }
  .showcase.slide-in-block {
    animation-delay: 0.2s;
  }
  .notebook.slide-in-block {
    animation-delay: 0.3s;
  }

  @keyframes slideInBlock {
    to {
      opacity: 1;
      filter: blur(0);
      transform: scale(1);
    }
  }
</style>
